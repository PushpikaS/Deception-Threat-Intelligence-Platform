POSTGRES_USER=honeypot
POSTGRES_PASSWORD=honeypot_secret
EVENTS_DB=honeypot_events
INTEL_DB=threat_intel

# Dedicated Redis instances (event bus, honeypot defense, platform cache/sessions)
REDIS_PASSWORD=changeme_redis_local

# Deception gateway (login, admin, fake API) — expose to attackers/scanners
HONEYPOT_PORT=8080

# Dashboard gateway (threat intel UI) — keep private / internal only
DASHBOARD_PORT=9090

CORS_ORIGINS=http://localhost:9090
VITE_API_URL=/api

# Engine / ingest tuning
POLL_INTERVAL=2
BATCH_SIZE=100
CACHE_TTL=30

# GeoIP — production: download MaxMind GeoLite2 into data/geoip/
#   MAXMIND_LICENSE_KEY=your_key .\scripts\download-geoip.ps1
GEOIP_CITY_PATH=/data/geoip/GeoLite2-City.mmdb
GEOIP_ASN_PATH=/data/geoip/GeoLite2-ASN.mmdb
GEOIP_HTTP_FALLBACK=true
GEOIP_CACHE_TTL=86400

# Dashboard auth (HttpOnly cookie sessions)
REQUIRE_DASHBOARD_AUTH=true
DASHBOARD_AUTH_USER=analyst
DASHBOARD_AUTH_PASS=changeme_local_only
DASHBOARD_SESSION_TTL=28800

COOKIE_SECURE=false
COOKIE_SAMESITE=lax

STRICT_PRODUCTION=false

# --- Microservice data stores (auto-wired in docker-compose) ---
# postgres-events  -> honeypot_events DB (raw events)
# postgres-intel   -> threat_intel DB (profiles, classifications, chains)
# redis-events     -> honeypot:events stream
# redis-defense    -> honeypot sessions + WAF/guard state
# redis-platform   -> dashboard sessions + API/engine cache
#
# Local dev outside Docker (optional overrides):
# EVENTS_DATABASE_URL=postgresql://honeypot:honeypot_secret@localhost:5432/honeypot_events
# INTEL_DATABASE_URL=postgresql://honeypot:honeypot_secret@localhost:5432/threat_intel
# REDIS_EVENTS_URL=redis://:changeme_redis_local@localhost:6379/0
# REDIS_DEFENSE_URL=redis://:changeme_redis_local@localhost:6379/1
# REDIS_PLATFORM_URL=redis://:changeme_redis_local@localhost:6379/2

# --- Production checklist ---
# 1. Change DASHBOARD_AUTH_PASS (16+ chars), POSTGRES_PASSWORD, REDIS_PASSWORD
# 2. Set STRICT_PRODUCTION=true
# 3. Restrict dashboard ports to internal networks
# 4. (Note: TLS certificates are no longer needed with HTTP-only setup)
# 5. After upgrading from monolithic DB: docker compose down -v && docker compose up --build -d